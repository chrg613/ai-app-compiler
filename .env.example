# ============================================
# Environment Configuration for AI App Compiler
# ============================================
# Copy this to .env and fill in your values

# ============================================
# Required: LLM Configuration
# ============================================
# Get your free API key from https://openrouter.ai
OPENROUTER_API_KEY=sk_live_your_api_key_here

# ============================================
# LLM Provider Settings
# ============================================
# Provider: openrouter (currently supported)
LLM_PROVIDER=openrouter

# Model: deepseek/deepseek-chat-v3-0324 (recommended) or other available models
LLM_MODEL=deepseek/deepseek-chat-v3-0324

# Temperature: 0.0-2.0 (lower = more deterministic, higher = more creative)
LLM_TEMPERATURE=0.1

# Max tokens for LLM response
LLM_MAX_TOKENS=4096

# ============================================
# Server Configuration
# ============================================
# Environment: development, test, production
ENVIRONMENT=development

# Server host and port
HOST=0.0.0.0
PORT=5000

# Flask specific
FLASK_ENV=production
FLASK_DEBUG=False

# ============================================
# Compiler Settings
# ============================================
# Timeout for compilation in seconds
COMPILER_TIMEOUT=60

# Maximum retries for LLM calls
COMPILER_MAX_RETRIES=3

# ============================================
# Frontend Configuration
# ============================================
FRONTEND_BUILD_DIR=build
STATIC_DIR=static
TEMPLATE_DIR=templates

# ============================================
# Logging
# ============================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins
CORS_ORIGINS=*

# ============================================
# Feature Flags
# ============================================
# Enable result caching
ENABLE_CACHING=True

# Enable metrics collection
ENABLE_METRICS=True

# ============================================
# Database (for future use)
# ============================================
DATABASE_URL=sqlite:///compiler.db

# ============================================
# Development Only
# ============================================
# (Remove or set to False in production)
DEBUG=False
TESTING=False
