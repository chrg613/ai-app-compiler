# Environment Configuration
# Copy this to .env and fill in your values

# OpenRouter API Key (Required)
OPENROUTER_API_KEY=

# Flask Configuration
FLASK_ENV=production
FLASK_APP=main.py
SECRET_KEY=your_secret_key_here

# Server Configuration
PORT=5000
DEBUG=False

# Database (optional for future use)
DATABASE_URL=

# Logging
LOG_LEVEL=INFO
