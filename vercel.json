{
  "version": 2,
  "buildCommand": "pip install -r requirements.txt && npm install",
  "devCommand": "python main.py",
  "installCommand": "pip install -r requirements.txt",
  "framework": "flask",
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.11"
      }
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/health",
      "dest": "/main.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "/main.py"
    }
  ],
  "env": {
    "ENVIRONMENT": "production",
    "FLASK_ENV": "production",
    "LOG_LEVEL": "INFO"
  },
  "git": {
    "deploymentEnabled": {
      "main": true,
      "compiler-system": true
    }
  },
  "regions": ["iad1"],
  "functions": {
    "main.py": {
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
