{
  "name": "ai-app-compiler",
  "version": "2.0.0",
  "description": "Production-ready AI Application Compiler with full multi-stage pipeline",
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "build": "docker build -t ai-app-compiler:latest .",
    "dev": "flask --app main run --debug",
    "start": "gunicorn --bind 0.0.0.0:5000 --workers 4 main:app",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "keywords": [
    "ai",
    "compiler",
    "code-generation",
    "application-builder",
    "schema-generation",
    "python",
    "flask"
  ],
  "author": "AI Compiler Team",
  "license": "MIT"
}
